# Core example inputs
# These are the only values most authenticated code samples need.
LIMITLESS_API_KEY=your_api_key_here
PRIVATE_KEY=your_private_key_here
MARKET_SLUG=bitcoin-2024

# Partner / API key v3 examples only
LIMITLESS_IDENTITY_TOKEN=
PARTNER_NAME=partner-a

# Optional example-runner overrides
# The SDK already has sensible defaults, so only set these when you need a non-default environment.
# API_URL=https://api.limitless.exchange
# WS_URL=wss://ws.limitless.exchange
# CHAIN_ID=8453

# Optional script toggles for specific examples
# PLACE_ORDER=false
# LIMITLESS_KEEP_DERIVED_TOKENS=1
# LIMITLESS_EXAMPLE_TRACE=0
# LIMITLESS_DELEGATED_ACCOUNT_READY_DELAY_MS=10000
# LIMITLESS_WS_LISTEN_MS=15000
# LIMITLESS_REVOKE_DERIVED_TOKEN=0

# Optional assertion overrides for api-key-v3 negative-path examples
# LIMITLESS_EXPECT_ACCOUNT_CREATION_ERROR=Requires apiToken auth with account_creation scope
# LIMITLESS_EXPECT_DELEGATED_SIGNING_ERROR=Requires delegated_signing scope|Signer does not match authenticated profile account|signature is required
# LIMITLESS_EXPECT_TRADING_SCOPE_ERROR=Requires trading scope
# LIMITLESS_EXPECT_REVOKED_TOKEN_ERROR=Invalid HMAC authentication
